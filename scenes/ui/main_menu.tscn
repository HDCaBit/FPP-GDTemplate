[gd_scene load_steps=2 format=3]

[sub_resource type="GDScript" id="SubResource_main_menu_script"]
script/source = "extends Control

func _ready() -> void:
	Input.set_mouse_mode(Input.MOUSE_MODE_VISIBLE)

func _on_new_game_pressed() -> void:
	GameManager.change_scene(\"res://scenes/core/world.tscn\")

func _on_continue_pressed() -> void:
	if SaveManager.has_save():
		SaveManager.load_game()
		var scene_path: String = SaveManager.read(\"scene\", \"res://scenes/core/world.tscn\")
		GameManager.change_scene(scene_path)

func _on_quit_pressed() -> void:
	get_tree().quit()
"

